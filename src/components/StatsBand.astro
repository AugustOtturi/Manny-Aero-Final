---
interface Stat {
  value: string;
  label: string;
}

interface Props {
  stats: Stat[];
}

const { stats } = Astro.props;
---

<section class="stats-band" aria-label="Key statistics">
  <div class="container">
    <div class="stats-band__grid reveal">
      {stats.map((s) => (
        <div class="stats-band__item">
          <div class="stats-band__value">{s.value}</div>
          <div class="stats-band__label">{s.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .stats-band {
    padding-block: clamp(32px, 5vh, 56px);
  }

  .stats-band__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--color-border);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    overflow: hidden;
    -webkit-backdrop-filter: blur(12px);
    backdrop-filter: blur(12px);
  }

  .stats-band__item {
    background: var(--color-surface);
    padding: clamp(24px, 3vw, 40px) clamp(20px, 2.5vw, 32px);
    display: flex;
    flex-direction: column;
    gap: 10px;
    transition: background-color 0.25s var(--ease-out);
  }

  .stats-band__item:hover {
    background: var(--color-surface-hover);
  }

  .stats-band__value {
    font-family: var(--font-display);
    font-size: clamp(32px, 4vw, 52px);
    font-weight: 400;
    line-height: 1;
    letter-spacing: -0.01em;
    color: var(--color-text);
    text-transform: uppercase;
    text-shadow:
      0 0 14px rgba(255, 255, 255, 0.45),
      0 0 32px rgba(255, 255, 255, 0.12),
      0 2px 14px rgba(0, 0, 0, 0.35);
  }

  .stats-band__label {
    font-size: var(--fs-label);
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    line-height: 1.3;
  }

  @media (max-width: 1024px) {
    .stats-band__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 560px) {
    .stats-band__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
