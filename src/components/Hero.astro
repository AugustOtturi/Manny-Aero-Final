---
import { Image } from "astro:assets";
import GlassButton from "./ui/GlassButton.astro";
import posterHero from "../assets/poster-hero.webp";
import heroVideo from "../assets/hero-manny-final.mp4?url";
---

<section class="hero" aria-labelledby="hero-title">
  <div class="hero__media" aria-hidden="true">
    <Image
      src={posterHero}
      alt=""
      widths={[640, 960, 1280, 1600, 1920]}
      sizes="100vw"
      loading="eager"
      fetchpriority="high"
      decoding="async"
      class="hero__poster"
    />
    <video
      id="hero-video"
      class="hero__video"
      src={heroVideo}
      autoplay
      muted
      loop
      playsinline
      preload="auto"
      tabindex="-1"
      aria-hidden="true"></video>
    <div class="hero__overlay"></div>
  </div>

  <a href="/" class="hero__logo hero-enter" style="--enter-delay: 360ms" aria-label="Manny Aero — Home">
    <img src="/logo-manny.svg" alt="Manny Aero" width="500" height="294" />
  </a>

  <div class="hero__inner container">
    <p class="hero__super hero-enter" style="--enter-delay: 0ms">With Manny, Mexico is yours!</p>
    <h1 id="hero-title" class="hero__title hero-enter" style="--enter-delay: 120ms">
      Seamless ops <br /> across Mexico <br /> delivered by experts.
    </h1>
    <div class="hero__cta hero-enter" style="--enter-delay: 240ms">
      <GlassButton href="#contact">
        <span class="hero__dot" aria-hidden="true"></span>
        24/7 Service — Request Now
      </GlassButton>
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    var video = document.getElementById("hero-video");
    var poster = document.querySelector(".hero__poster");
    if (!video || !poster) return;

    var revealed = false;
    function reveal() {
      if (revealed) return;
      revealed = true;
      poster.classList.add("is-gone");
    }

    video.addEventListener("playing", reveal, { once: true });
    if (!video.paused && video.readyState >= 2) reveal();

    // CSS fallback at 4 s covers cases where playing never fires
    setTimeout(reveal, 2500);
  })();
</script>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    padding-top: 120px;
    padding-bottom: 80px;
    overflow: hidden;
  }

  .hero__media {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
    background: #0a0a0f;
  }

  .hero__poster {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    filter: grayscale(1) brightness(0.9);
    z-index: 2;
    transition: opacity 0.8s var(--ease-out);
    /* CSS fallback: fade out after 4 s even if JS is deferred */
    animation: posterHide 0.8s var(--ease-out) 4s forwards;
  }

  .hero__poster.is-gone {
    opacity: 0;
    animation: none;
    pointer-events: none;
  }

  @keyframes posterHide {
    to { opacity: 0; }
  }

  .hero__video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    pointer-events: none;
    border: 0;
    filter: grayscale(1) brightness(0.9);
    z-index: 1;
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    z-index: 3;
    background: linear-gradient(
      180deg,
      rgba(0, 0, 0, 0.35) 0%,
      rgba(0, 0, 0, 0.55) 60%,
      rgba(2, 2, 8, 0.9) 100%
    );
  }

  .hero__logo {
    position: absolute;
    top: 32px;
    left: var(--pad-x);
    z-index: 10;
    display: inline-flex;
    align-items: center;
    line-height: 0;
  }

  .hero__logo img {
    display: block;
    height: 100px;
    width: auto;
    filter: drop-shadow(0 4px 20px rgba(0, 0, 0, 0.5));
  }

  .hero__inner {
    position: relative;
    z-index: 2;
    max-width: 1100px;
  }

  .hero__super {
    font-size: var(--fs-label);
    font-weight: 700;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--color-text);
    margin-bottom: 28px;
  }

  .hero__title {
    font-size: var(--fs-hero);
    font-weight: 900;
    line-height: 1.02;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    color: var(--color-text);
    margin-bottom: 44px;
    text-shadow: 0 2px 40px rgba(0, 0, 0, 0.4);
  }

  .hero__cta {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  .hero__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-accent);
    box-shadow: 0 0 0 3px rgba(255, 185, 0, 0.25);
    animation: heroPulse 2s var(--ease-in-out) infinite;
  }

  @keyframes heroPulse {
    0%,
    100% {
      box-shadow: 0 0 0 3px rgba(255, 185, 0, 0.25);
    }
    50% {
      box-shadow: 0 0 0 8px rgba(255, 185, 0, 0);
    }
  }

  @media (max-width: 768px) {
    .hero {
      padding-top: 100px;
      padding-bottom: 60px;
    }
    .hero__title br {
      display: none;
    }
    .hero__title {
      margin-bottom: 32px;
    }
    .hero__logo {
      top: 24px;
    }
    .hero__logo img {
      height: 64px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__poster {
      animation: none;
      transition: none;
    }
  }
</style>
