---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import StatsBand from "../components/StatsBand.astro";
import { PERMIT_SECTIONS, DOWNLOADS } from "../data/permits";

const stats = [
  { value: "Fastest", label: "Turnaround Time" },
  { value: "100%", label: "First-Time Approval" },
  { value: "All Regions", label: "Coverage in Mexico" },
  { value: "24/7", label: "Permit Processing" },
];

const sidebarItems = [
  { id: "far91", label: "FAR Part 91" },
  { id: "far135-single", label: "FAR 135 — Single Event" },
  { id: "far135-foreign", label: "FAR 135 — Foreign Op." },
  { id: "ibp", label: "Blanket Permit (IBP)" },
  { id: "overflights", label: "Overflights" },
  { id: "downloads", label: "Downloads" },
];
---

<BaseLayout
  title="Permits & Authorizations — Manny Aero"
  description="Everything you need to operate in Mexican airspace — requirements by flight category with direct support from our regulatory team."
  activeLink="services"
>
  <PageHero
    badge="Regulatory Services"
    title="Permits & Authorizations."
    subtitle="Everything you need to operate in Mexican airspace — requirements by flight category and direct support from our regulatory team."
    accent="Authorizations."
  />

  <StatsBand stats={stats} />

  <section class="permits-section">
    <div class="container page-wrap">
      <aside class="sidebar">
        <div class="sidebar-title">Jump to section</div>
        <nav class="sidebar-nav" aria-label="Page sections">
          {
            sidebarItems.map((item, i) => (
              <a
                class={`sidebar-link ${i === 0 ? "active" : ""}`}
                data-target={item.id}
                href={`#${item.id}`}
              >
                <span class="sidebar-dot" />
                {item.label}
              </a>
            ))
          }
        </nav>
      </aside>

      <main class="content">
        {
          PERMIT_SECTIONS.map((s) => (
            <div class={`permit-section reveal ${s.open ? "open" : ""}`} id={s.id}>
              <button class="permit-header" type="button" aria-expanded={!!s.open}>
                <span class="permit-badge">{s.badge}</span>
                <span class="permit-title">{s.title}</span>
                <span class="permit-toggle">
                  <svg viewBox="0 0 24 24">
                    <polyline points="6 9 12 15 18 9" />
                  </svg>
                </span>
              </button>
              <div class="permit-body">
                {s.noteBefore && (
                  <div class="permit-note permit-note-before">{s.noteBefore}</div>
                )}
                <ul class="permit-list">
                  {s.items.map((it) => (
                    <li>{it}</li>
                  ))}
                </ul>
                {s.noteAfter && <div class="permit-note">{s.noteAfter}</div>}
              </div>
            </div>
          ))
        }

        <div id="downloads" class="downloads-wrap reveal">
          <div class="downloads-header">
            <h2 class="downloads-title">
              <span class="accent">Downloadable</span> Templates
            </h2>
            <span class="downloads-count">{DOWNLOADS.length} files</span>
          </div>

          <div class="downloads-grid">
            {
              DOWNLOADS.map((d) => (
                <button
                  class="download-card"
                  type="button"
                  data-file-name={d.name}
                  data-file-url={d.url}
                >
                  <div class="download-icon">
                    {d.icon === "check" ? (
                      <svg viewBox="0 0 24 24">
                        <polyline points="9 11 12 14 22 4" />
                        <path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11" />
                      </svg>
                    ) : d.icon === "star" ? (
                      <svg viewBox="0 0 24 24">
                        <polygon points="3 11 22 2 13 21 11 13 3 11" />
                      </svg>
                    ) : d.icon === "send" ? (
                      <svg viewBox="0 0 24 24">
                        <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z" />
                      </svg>
                    ) : d.icon === "shield" ? (
                      <svg viewBox="0 0 24 24">
                        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
                      </svg>
                    ) : d.icon === "plane" ? (
                      <svg viewBox="0 0 24 24">
                        <path d="M17.8 19.2L16 11l3.5-3.5C21 6 21 4 19.5 2.5S18 2 16.5 3.5L13 7 4.8 5.2C4.2 5 3.5 5.3 3 5.8l-.5.5c-.5.5-.6 1.2-.2 1.7l4.9 5.8-1.9 5.5c-.3.6.1 1.3.7 1.6l.5.2c.5.2 1.1 0 1.4-.5l3.5-5.5 5.8 4.9c.5.4 1.2.3 1.7-.2l.5-.5c.5-.5.8-1.2.6-1.8z" />
                      </svg>
                    ) : (
                      <svg viewBox="0 0 24 24">
                        <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z" />
                        <polyline points="14 2 14 8 20 8" />
                        <line x1="16" y1="13" x2="8" y2="13" />
                        <line x1="16" y1="17" x2="8" y2="17" />
                      </svg>
                    )}
                  </div>
                  <div class="download-name">{d.name}</div>
                  <div class="download-type">{d.type}</div>
                  <div class="download-action">
                    Download
                    <svg viewBox="0 0 24 24">
                      <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4" />
                      <polyline points="7 10 12 15 17 10" />
                      <line x1="12" y1="15" x2="12" y2="3" />
                    </svg>
                  </div>
                </button>
              ))
            }
          </div>
        </div>
      </main>
    </div>
  </section>

  <!-- EMAIL GATE MODAL -->
  <div class="gate-overlay" id="gateOverlay">
    <div class="gate-modal" id="gateModal">
      <button class="gate-close" id="gateCloseBtn" type="button" aria-label="Close">
        <svg viewBox="0 0 24 24">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>

      <div class="gate-icon">
        <svg viewBox="0 0 24 24">
          <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"></path>
          <polyline points="7 10 12 15 17 10"></polyline>
          <line x1="12" y1="15" x2="12" y2="3"></line>
        </svg>
      </div>

      <div class="gate-label">Free Download</div>
      <h3 class="gate-title">One step before<br />your download</h3>
      <div class="gate-file" id="gateFileName">SENEAM POA Manny</div>
      <p class="gate-desc">
        Enter your email to access the download. We'll also keep you updated with regulatory
        changes that affect your operations in Mexico.
      </p>

      <form class="gate-form" id="gateForm">
        <input
          class="gate-input"
          type="email"
          placeholder="name@operator.com"
          id="gateEmail"
          required
        />
        <button class="gate-submit" type="submit">
          Access download
          <svg viewBox="0 0 24 24">
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </button>
        <p class="gate-privacy">No spam, ever. We respect your inbox as much as your schedule.</p>
      </form>

      <div class="gate-success" id="gateSuccess">
        <div class="success-icon">
          <svg viewBox="0 0 24 24">
            <polyline points="20 6 9 17 4 12"></polyline>
          </svg>
        </div>
        <div class="success-title">You're all set</div>
        <p class="success-desc">
          Your download is ready. We've also noted your email for regulatory updates.
        </p>
        <a class="success-dl" id="successLink" href="#" download>
          Download file
          <svg viewBox="0 0 24 24">
            <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"></path>
            <polyline points="7 10 12 15 17 10"></polyline>
            <line x1="12" y1="15" x2="12" y2="3"></line>
          </svg>
        </a>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  // Accordion
  document.querySelectorAll<HTMLButtonElement>(".permit-header").forEach((btn) => {
    btn.addEventListener("click", () => {
      const section = btn.closest(".permit-section");
      if (!section) return;
      const willOpen = !section.classList.contains("open");
      section.classList.toggle("open");
      btn.setAttribute("aria-expanded", String(willOpen));
    });
  });

  // Sidebar scroll-sync
  const OFFSET = 130;
  const links = document.querySelectorAll<HTMLAnchorElement>(".sidebar-link");

  function getActiveId(): string | null {
    const sections = Array.from(
      document.querySelectorAll<HTMLElement>(".permit-section, #downloads")
    );
    if (sections.length === 0) return null;

    const scrollBottom = window.scrollY + window.innerHeight;
    const pageHeight = document.documentElement.scrollHeight;
    if (scrollBottom >= pageHeight - 60) return "downloads";

    let active = sections[0];
    for (const s of sections) {
      if (s.getBoundingClientRect().top <= OFFSET) active = s;
    }
    return active.id;
  }

  function syncSidebar() {
    const id = getActiveId();
    links.forEach((l) => {
      l.classList.toggle("active", l.dataset.target === id);
    });
  }

  window.addEventListener("scroll", syncSidebar, { passive: true });
  syncSidebar();

  links.forEach((link) => {
    link.addEventListener("click", (e) => {
      e.preventDefault();
      const targetId = link.dataset.target;
      if (!targetId) return;
      const target = document.getElementById(targetId);
      if (!target) return;
      if (target.classList.contains("permit-section") && !target.classList.contains("open")) {
        target.classList.add("open");
        target
          .querySelector<HTMLButtonElement>(".permit-header")
          ?.setAttribute("aria-expanded", "true");
      }
      const top = target.getBoundingClientRect().top + window.scrollY - OFFSET + 16;
      window.scrollTo({ top, behavior: "smooth" });
    });
  });

  // Email gate
  const overlay = document.getElementById("gateOverlay") as HTMLDivElement | null;
  const modal = document.getElementById("gateModal") as HTMLDivElement | null;
  const form = document.getElementById("gateForm") as HTMLFormElement | null;
  const emailInput = document.getElementById("gateEmail") as HTMLInputElement | null;
  const fileNameEl = document.getElementById("gateFileName");
  const successEl = document.getElementById("gateSuccess");
  const successLink = document.getElementById("successLink") as HTMLAnchorElement | null;
  const closeBtn = document.getElementById("gateCloseBtn");

  let currentFileUrl = "#";
  let currentFileName = "";

  function isRegistered(): boolean {
    try {
      return !!localStorage.getItem("manny_email");
    } catch {
      return false;
    }
  }

  function triggerDownload(url: string, name: string) {
    const a = document.createElement("a");
    a.href = url;
    a.download = name;
    a.click();
  }

  function openGate(fileName: string, fileUrl: string) {
    currentFileUrl = fileUrl;
    currentFileName = fileName;
    if (isRegistered()) {
      triggerDownload(fileUrl, fileName);
      return;
    }
    if (fileNameEl) fileNameEl.textContent = fileName;
    form?.classList.remove("hide");
    successEl?.classList.remove("show");
    if (emailInput) {
      emailInput.value = "";
      emailInput.style.borderColor = "";
    }
    overlay?.classList.add("open");
    document.body.style.overflow = "hidden";
    setTimeout(() => emailInput?.focus(), 350);
  }

  function closeGate() {
    overlay?.classList.remove("open");
    document.body.style.overflow = "";
  }

  document.querySelectorAll<HTMLButtonElement>(".download-card").forEach((card) => {
    card.addEventListener("click", () => {
      const name = card.dataset.fileName ?? "";
      const url = card.dataset.fileUrl ?? "#";
      openGate(name, url);
    });
  });

  form?.addEventListener("submit", (e) => {
    e.preventDefault();
    const email = emailInput?.value.trim() ?? "";
    const valid = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
    if (!valid) {
      if (emailInput) {
        emailInput.style.borderColor = "#e84040";
        emailInput.focus();
      }
      return;
    }
    if (emailInput) emailInput.style.borderColor = "";
    try {
      localStorage.setItem("manny_email", email);
    } catch {
      /* ignore */
    }
    if (successLink) {
      successLink.href = currentFileUrl;
      successLink.download = currentFileName;
    }
    form.classList.add("hide");
    successEl?.classList.add("show");
  });

  closeBtn?.addEventListener("click", closeGate);
  overlay?.addEventListener("click", closeGate);
  modal?.addEventListener("click", (e) => e.stopPropagation());
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeGate();
  });
</script>

<style>
  .permits-section {
    padding-block: clamp(48px, 8vh, 96px);
  }

  .page-wrap {
    display: grid;
    grid-template-columns: 260px 1fr;
    gap: 56px;
    align-items: start;
  }

  .sidebar {
    position: sticky;
    top: 110px;
    padding: 20px 18px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background: var(--color-surface);
    -webkit-backdrop-filter: blur(12px);
    backdrop-filter: blur(12px);
  }
  .sidebar-title {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 16px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--color-border);
  }
  .sidebar-nav {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .sidebar-link {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 14px;
    border-radius: 6px;
    font-size: 14px;
    font-weight: 500;
    color: var(--color-text-muted);
    cursor: pointer;
    transition: all 0.25s var(--ease-out);
    border-left: 2px solid transparent;
  }
  .sidebar-link:hover {
    color: var(--color-text);
    background: rgba(255, 255, 255, 0.04);
  }
  .sidebar-link.active {
    color: var(--color-accent);
    border-left-color: var(--color-accent);
    background: rgba(255, 185, 0, 0.08);
    font-weight: 700;
  }
  .sidebar-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: currentColor;
    flex-shrink: 0;
    opacity: 0.5;
  }
  .sidebar-link.active .sidebar-dot {
    opacity: 1;
    background: var(--color-accent);
  }

  .content {
    min-width: 0;
  }

  .permit-section {
    margin-bottom: 20px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--color-surface);
    -webkit-backdrop-filter: blur(12px);
    backdrop-filter: blur(12px);
    transition: border-color 0.25s var(--ease-out);
  }
  .permit-section:hover {
    border-color: var(--color-border-strong);
  }
  .permit-header {
    width: 100%;
    padding: 26px 30px;
    border: none;
    border-bottom: 1px solid transparent;
    background: transparent;
    display: flex;
    align-items: center;
    gap: 16px;
    cursor: pointer;
    transition: background-color 0.2s var(--ease-out);
    font-family: var(--font-sans);
    text-align: left;
  }
  .permit-section.open .permit-header {
    border-bottom-color: var(--color-border);
  }
  .permit-header:hover {
    background: rgba(255, 255, 255, 0.03);
  }
  .permit-badge {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-accent);
    background: rgba(255, 185, 0, 0.1);
    border: 1px solid rgba(255, 185, 0, 0.25);
    padding: 4px 10px;
    border-radius: var(--radius-pill);
    white-space: nowrap;
    flex-shrink: 0;
  }
  .permit-title {
    font-size: 16px;
    font-weight: 700;
    color: var(--color-text);
    flex: 1;
    line-height: 1.3;
  }
  .permit-toggle {
    width: 30px;
    height: 30px;
    border-radius: 50%;
    border: 1px solid var(--color-border-strong);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: all 0.25s var(--ease-out);
  }
  .permit-toggle svg {
    width: 14px;
    height: 14px;
    stroke: var(--color-text-muted);
    fill: none;
    stroke-width: 2;
    transition: transform 0.3s var(--ease-out);
  }
  .permit-section.open .permit-toggle {
    border-color: var(--color-accent);
  }
  .permit-section.open .permit-toggle svg {
    stroke: var(--color-accent);
    transform: rotate(180deg);
  }
  .permit-body {
    display: none;
    padding: 28px 30px;
  }
  .permit-section.open .permit-body {
    display: block;
  }
  .permit-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 0;
    margin: 0;
  }
  .permit-list li {
    display: flex;
    gap: 14px;
    font-size: 15px;
    font-weight: 400;
    color: var(--color-text-muted);
    line-height: 1.65;
  }
  .permit-list li::before {
    content: "";
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--color-accent);
    flex-shrink: 0;
    margin-top: 9px;
  }
  .permit-note {
    margin-top: 18px;
    padding: 14px 18px;
    background: rgba(255, 185, 0, 0.07);
    border-left: 2px solid var(--color-accent);
    border-radius: 0 8px 8px 0;
    font-size: 14px;
    color: var(--color-text-muted);
    font-style: italic;
    line-height: 1.6;
  }
  .permit-note-before {
    margin-top: 0;
    margin-bottom: 22px;
  }

  .downloads-wrap {
    margin-top: 56px;
  }
  .downloads-header {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 28px;
    padding-bottom: 18px;
    border-bottom: 1px solid var(--color-border);
  }
  .downloads-title {
    font-family: var(--font-display);
    font-size: clamp(28px, 3vw, 40px);
    font-weight: 400;
    color: var(--color-text);
    flex: 1;
    letter-spacing: -0.01em;
    line-height: 1.05;
    text-transform: uppercase;
    margin: 0;
  }
  .downloads-count {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    background: var(--color-surface);
    padding: 6px 12px;
    border-radius: var(--radius-pill);
    border: 1px solid var(--color-border);
  }

  .downloads-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 16px;
  }
  .download-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 22px;
    cursor: pointer;
    transition: all 0.25s var(--ease-out);
    display: flex;
    flex-direction: column;
    gap: 12px;
    text-align: left;
    font-family: var(--font-sans);
    -webkit-backdrop-filter: blur(12px);
    backdrop-filter: blur(12px);
  }
  .download-card:hover {
    border-color: var(--color-accent);
    background: rgba(255, 185, 0, 0.06);
    transform: translateY(-2px);
  }
  .download-icon {
    width: 42px;
    height: 42px;
    border-radius: 10px;
    background: rgba(255, 185, 0, 0.1);
    border: 1px solid rgba(255, 185, 0, 0.25);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .download-icon svg {
    width: 20px;
    height: 20px;
    stroke: var(--color-accent);
    fill: none;
    stroke-width: 1.5;
  }
  .download-name {
    font-size: 14px;
    font-weight: 700;
    color: var(--color-text);
    line-height: 1.4;
    flex: 1;
  }
  .download-type {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }
  .download-action {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-top: 4px;
  }
  .download-action svg {
    width: 12px;
    height: 12px;
    stroke: currentColor;
    fill: none;
    stroke-width: 2;
  }

  /* Gate overlay */
  .gate-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.7);
    z-index: 9999;
    align-items: center;
    justify-content: center;
    padding: 24px;
    -webkit-backdrop-filter: blur(4px);
    backdrop-filter: blur(4px);
  }
  .gate-overlay.open {
    display: flex;
  }
  .gate-modal {
    background: rgba(18, 18, 24, 0.96);
    border: 1px solid var(--color-border-strong);
    border-radius: var(--radius-lg);
    width: 100%;
    max-width: 460px;
    padding: 40px;
    position: relative;
    box-shadow: 0 24px 80px rgba(0, 0, 0, 0.5);
    transform: translateY(16px);
    opacity: 0;
    transition: all 0.3s cubic-bezier(0.32, 0.72, 0, 1);
    -webkit-backdrop-filter: blur(20px);
    backdrop-filter: blur(20px);
  }
  .gate-overlay.open .gate-modal {
    transform: translateY(0);
    opacity: 1;
  }

  .gate-close {
    position: absolute;
    top: 14px;
    right: 14px;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: 1px solid var(--color-border);
    background: rgba(255, 255, 255, 0.04);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: var(--color-text-muted);
    transition: all 0.2s var(--ease-out);
  }
  .gate-close:hover {
    color: var(--color-text);
    background: rgba(255, 255, 255, 0.1);
  }
  .gate-close svg {
    width: 12px;
    height: 12px;
    stroke: currentColor;
    fill: none;
    stroke-width: 2;
  }

  .gate-icon {
    width: 54px;
    height: 54px;
    border-radius: 14px;
    background: rgba(255, 185, 0, 0.1);
    border: 1px solid rgba(255, 185, 0, 0.28);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 22px;
  }
  .gate-icon svg {
    width: 26px;
    height: 26px;
