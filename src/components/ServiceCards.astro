---
import { SERVICES } from "../data/services";
import GlassPill from "./ui/GlassPill.astro";
---

<section class="services section" id="services" aria-labelledby="services-title">
  <div class="container">
    <div class="services__intro reveal">
      <h2 id="services-title" class="services__title">
        Ready for every flight.
      </h2>
      <p class="services__subtitle">
        End-to-end support —
        <span class="accent">smooth, efficient, and stress-free</span>
        from start to finish.
      </p>
    </div>

    <div class="services__grid">
      {
        SERVICES.map((s, i) => (
          <a
            href={s.href}
            class={`card card--${s.tone} reveal`}
            style={`--delay:${i * 80}ms`}
          >
            <div
              class="card__img"
              style={`background-image: url(${s.image})`}
              aria-hidden="true"
            />
            <div class="card__overlay" aria-hidden="true" />

            <div class="card__top">
              <GlassPill>Explore More</GlassPill>
            </div>

            <div class="card__bottom">
              <h3 class="card__title">{s.title}</h3>
              <span class="card__arrow" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
                  <path
                    d="M3 9H15M15 9L10 4M15 9L10 14"
                    stroke="currentColor"
                    stroke-width="1.6"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
              </span>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>

<style>
  .services {
    padding-block: clamp(56px, 8vh, 96px);
  }

  .services__intro {
    max-width: 880px;
    margin: 0 auto 44px;
    text-align: center;
    transition-delay: 0.05s;
  }

  .services__title {
    font-size: var(--fs-h2);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    color: var(--color-text);
    margin-bottom: 14px;
  }

  .services__subtitle {
    font-size: var(--fs-lead);
    line-height: 1.5;
    color: var(--color-text-muted);
    max-width: 680px;
    margin: 0 auto;
  }

  .services__subtitle .accent {
    color: var(--color-accent);
  }

  .services__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 18px;
  }

  .card {
    position: relative;
    aspect-ratio: 2 / 3;
    border-radius: var(--radius-lg);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 20px 22px 26px;
    box-shadow:
      0 18px 40px rgba(0, 0, 0, 0.55),
      0 6px 14px rgba(0, 0, 0, 0.35),
      0 1px 2px rgba(0, 0, 0, 0.4),
      inset 0 0 0 1px rgba(255, 255, 255, 0.35);
    transition: transform 0.5s var(--ease-out), box-shadow 0.5s var(--ease-out);
    isolation: isolate;
    transition-delay: var(--delay, 0ms);
  }

  .card:hover {
    transform: translateY(-6px);
    box-shadow:
      0 28px 60px rgba(0, 0, 0, 0.65),
      0 10px 20px rgba(0, 0, 0, 0.4),
      0 1px 2px rgba(0, 0, 0, 0.45),
      inset 0 0 0 1px rgba(255, 255, 255, 0.4);
  }

  .card__img {
    position: absolute;
    inset: 0;
    z-index: -2;
    background-color: #1a1a20;
    background-size: cover;
    background-position: center;
    filter: brightness(0.98) saturate(1.05);
    transition: transform 0.8s var(--ease-out);
  }

  .card:hover .card__img {
    transform: scale(1.06);
  }

  .card__overlay {
    position: absolute;
    inset: 0;
    z-index: -1;
    background: linear-gradient(
      180deg,
      rgba(0, 0, 0, 0.15) 0%,
      rgba(0, 0, 0, 0.2) 40%,
      rgba(0, 0, 0, 0.8) 100%
    );
    box-shadow: inset 0 0 24px rgba(0, 0, 0, 0.12);
  }

  .card__top {
    display: flex;
  }

  .card__bottom {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 12px;
  }

  .card__title {
    font-size: clamp(15px, 1.2vw, 18px);
    font-weight: 700;
    line-height: 1.25;
    color: var(--color-text);
    max-width: 180px;
  }

  .card__arrow {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.2);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text);
    flex-shrink: 0;
    transition: background-color 0.3s var(--ease-out), color 0.3s var(--ease-out);
  }

  .card:hover .card__arrow {
    background: var(--color-accent);
    color: #0a0a0a;
    border-color: var(--color-accent);
  }

  @media (max-width: 1024px) {
    .services__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 24px;
    }
    .card {
      aspect-ratio: 3 / 4;
    }
    .card__title {
      font-size: 15px;
    }
  }

  @media (max-width: 640px) {
    .services__grid {
      grid-template-columns: 1fr 1fr;
      gap: 20px;
    }
    .card {
      aspect-ratio: 3 / 4;
      padding: 16px 16px 20px;
    }
    .services__intro {
      margin-bottom: 32px;
    }
  }

  @media (max-width: 420px) {
    .services__grid {
      grid-template-columns: 1fr;
      gap: 20px;
    }
    .card {
      aspect-ratio: 16 / 10;
    }
  }
</style>
