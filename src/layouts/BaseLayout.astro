---
import "../styles/global.css";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import interHeavy from "@fontsource/inter/files/inter-latin-900-normal.woff2?url";
import interExtraBold from "@fontsource/inter/files/inter-latin-800-normal.woff2?url";

type ActiveLink = "home" | "about" | "services" | "map" | "blog" | "contact";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  activeLink?: ActiveLink;
}

const {
  title,
  description = "Manny Aero — Premium aircraft ground handling, permits, catering and FBO coordination across Mexico. Trusted by 300+ operators, 10,000+ operations handled.",
  ogImage = "/og-default.jpg",
  activeLink = "home",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();
const ogImageURL = new URL(ogImage, Astro.site).toString();

const orgJsonLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "Manny Aero",
  url: Astro.site?.toString(),
  logo: new URL("/favicon.svg", Astro.site).toString(),
  description:
    "Premium aircraft ground handling, permits, catering and FBO coordination across Mexico.",
  address: {
    "@type": "PostalAddress",
    addressCountry: "MX",
  },
  contactPoint: [
    {
      "@type": "ContactPoint",
      telephone: "+1-877-50-MANNY",
      contactType: "customer service",
      areaServed: ["US", "CA"],
      availableLanguage: ["English", "Spanish"],
    },
    {
      "@type": "ContactPoint",
      telephone: "+52-722-273-0981",
      contactType: "customer service",
      areaServed: "MX",
      availableLanguage: ["Spanish", "English"],
    },
  ],
  sameAs: [
    "https://www.linkedin.com/company/manny-aero",
    "https://www.instagram.com/manny.aero",
    "https://www.facebook.com/manny.aero",
    "https://www.youtube.com/@manny-aero",
    "https://www.tiktok.com/@manny.aero",
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#0a0a0f" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Manny Aero" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="en_US" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />

    <link rel="preload" href={interHeavy} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={interExtraBold} as="font" type="font/woff2" crossorigin />

    <script
      type="application/ld+json"
      set:html={JSON.stringify(orgJsonLd)}
    />

    <style is:inline>
      html:not(.is-ready) body {
        overflow: hidden;
      }
      .app-loader {
        position: fixed;
        inset: 0;
        z-index: 9999;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 28px;
        background: #0a0a0f;
        transition: opacity 0.45s var(--ease-out);
      }
      .app-loader__logo {
        width: 220px;
        height: auto;
        opacity: 0.95;
        filter: drop-shadow(0 4px 20px rgba(0, 0, 0, 0.5));
      }
      .app-loader__bar {
        position: relative;
        width: 200px;
        height: 1px;
        background: rgba(255, 255, 255, 0.08);
        overflow: hidden;
        border-radius: 999px;
      }
      .app-loader__bar span {
        position: absolute;
        inset: 0;
        background: var(--color-accent);
        transform: translateX(-100%);
        animation: appLoaderBar 1.1s var(--ease-out) forwards;
      }
      @keyframes appLoaderBar {
        to { transform: translateX(0); }
      }
      .app-loader.is-gone {
        opacity: 0;
        pointer-events: none;
      }
      @media (max-width: 640px) {
        .app-loader__logo {
          width: 160px;
        }
        .app-loader__bar {
          width: 160px;
        }
      }
    </style>

    <slot name="head" />
  </head>
  <body data-active-link={activeLink}>
    <div class="app-loader" id="app-loader" aria-hidden="true">
      <img src="/logo-manny.svg" alt="" width="220" height="130" class="app-loader__logo" />
      <div class="app-loader__bar"><span></span></div>
    </div>

    <script is:inline>
      (function () {
        var loader = document.getElementById("app-loader");
        var start = performance.now();
        var MIN_SHOW = 1100;
        var prefersReduced =
          window.matchMedia &&
          window.matchMedia("(prefers-reduced-motion: reduce)").matches;
        var finished = false;

        function finish() {
          if (finished) return;
          finished = true;
          var elapsed = performance.now() - start;
          var wait = prefersReduced ? 0 : Math.max(0, MIN_SHOW - elapsed);
          setTimeout(function () {
            document.documentElement.classList.add("is-ready");
            if (!loader) return;
            loader.classList.add("is-gone");
            var removed = false;
            var remove = function () {
              if (removed) return;
              removed = true;
              if (loader && loader.parentNode) loader.parentNode.removeChild(loader);
            };
            loader.addEventListener("transitionend", remove, { once: true });
            setTimeout(remove, 900);
          }, wait);
        }

        if (document.readyState === "complete") {
          finish();
        } else {
          window.addEventListener("load", finish, { once: true });
          // Safety net — load may never fire if an embedded iframe stalls.
          setTimeout(finish, 6000);
        }
      })();
    </script>

    <svg width="0" height="0" style="position:absolute" aria-hidden="true">
      <filter id="grain">
        <feTurbulence type="fractalNoise" baseFrequency="0.65" numOctaves="3" />
        <feColorMatrix type="saturate" values="0" />
      </filter>
    </svg>

    <div class="bg-blobs" aria-hidden="true">
      <span class="blob blob--right blob--1"></span>
      <span class="blob blob--right blob--2"></span>
      <span class="blob blob--left  blob--3"></span>
    </div>
    <div class="bg-noise" aria-hidden="true"></div>

    <Navbar activeLink={activeLink} />

    <main id="main">
      <slot />
    </main>

    <Footer />

    <script>
      // Navbar scroll state + scroll-reveal observer
      const body = document.body;
      let ticking = false;

      const onScroll = () => {
        if (!ticking) {
          requestAnimationFrame(() => {
            body.dataset.scrolled = window.scrollY > 40 ? "true" : "false";
            ticking = false;
          });
          ticking = true;
        }
      };
      window.addEventListener("scroll", onScroll, { passive: true });
      onScroll();

      // Reveal on scroll
      const prefersReducedMotion = window.matchMedia(
        "(prefers-reduced-motion: reduce)"
      ).matches;

      if (!prefersReducedMotion && "IntersectionObserver" in window) {
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                e.target.classList.add("in-view");
                io.unobserve(e.target);
              }
            });
          },
          { rootMargin: "0px 0px -4% 0px", threshold: 0.04 }
        );
        document.querySelectorAll<HTMLElement>(".reveal").forEach((el) => io.observe(el));
      } else {
        document.querySelectorAll<HTMLElement>(".reveal").forEach((el) =>
          el.classList.add("in-view")
        );
      }
    </script>
  </body>
</html>
