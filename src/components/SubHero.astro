---
import { Image } from "astro:assets";
import GlassButton from "./ui/GlassButton.astro";
import featureImg from "../assets/photos/subhero-feature.jpg";
import photo1 from "../assets/photos/subhero-1.jpg";
import photo2 from "../assets/photos/subhero-2.jpg";
import photo3 from "../assets/photos/subhero-3.jpg";
---

<section class="subhero section" id="about" aria-labelledby="subhero-title">
  <div class="container">
    <div class="subhero__grid">
      <article class="subhero__feature reveal">
        <Image
          src={featureImg}
          alt=""
          widths={[640, 960, 1280, 1600]}
          sizes="(max-width: 1024px) 100vw, 60vw"
          loading="lazy"
          decoding="async"
          class="subhero__feature-img"
        />
        <div class="subhero__feature-overlay" aria-hidden="true"></div>
        <div class="subhero__feature-content">
          <p class="subhero__years">
            <span class="subhero__years-num">25+</span>
          </p>
          <h2 id="subhero-title" class="subhero__title">
            Years of experience,<br />
            precision and trust
          </h2>
          <p class="subhero__desc">
            FBO coordination, permits, catering, and ground handling — executed
            with precision, 24/7.
          </p>
          <GlassButton href="#about" variant="outline">Meet Our Founder</GlassButton>
        </div>
      </article>

      <div class="subhero__stack">
        <div class="subhero__photo reveal">
          <Image
            src={photo1}
            alt="Manny agents on tarmac"
            widths={[400, 640, 1000]}
            sizes="(max-width: 1024px) 33vw, 25vw"
            loading="lazy"
            decoding="async"
            class="subhero__photo-bg"
          />
        </div>
        <div class="subhero__photo reveal">
          <Image
            src={photo2}
            alt="Technician working on landing gear"
            widths={[400, 640, 1000]}
            sizes="(max-width: 1024px) 33vw, 25vw"
            loading="lazy"
            decoding="async"
            class="subhero__photo-bg"
          />
        </div>
        <div class="subhero__photo reveal">
          <Image
            src={photo3}
            alt="Operations dispatcher with headset"
            widths={[400, 640, 1000]}
            sizes="(max-width: 1024px) 33vw, 25vw"
            loading="lazy"
            decoding="async"
            class="subhero__photo-bg"
          />
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .subhero__grid {
    display: grid;
    grid-template-columns: minmax(0, 1.5fr) minmax(0, 1fr);
    gap: 24px;
    align-items: stretch;
  }

  .subhero__feature {
    position: relative;
    border-radius: var(--radius-lg);
    overflow: hidden;
    min-height: 640px;
    box-shadow:
      0 18px 40px rgba(0, 0, 0, 0.55),
      0 6px 14px rgba(0, 0, 0, 0.35),
      0 1px 2px rgba(0, 0, 0, 0.4),
      inset 0 0 0 1px rgba(255, 255, 255, 0.35);
    isolation: isolate;
  }

  .subhero__feature-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    background-color: #1a1a20;
    filter: brightness(0.98) saturate(1.05);
    z-index: -2;
  }

  .subhero__feature-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(168, 164, 164, 0.05) 0%,
      rgba(109, 102, 102, 0.35) 50%,
      rgba(97, 92, 92, 0.85) 100%
    );
    box-shadow: inset 0 0 24px rgba(0, 0, 0, 0.12);
    z-index: -1;
  }

  .subhero__feature-content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 44px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 18px;
  }

  .subhero__years-num {
    font-size: clamp(48px, 6vw, 76px);
    font-weight: 900;
    color: var(--color-accent);
    letter-spacing: -0.03em;
    line-height: 1;
  }

  .subhero__title {
    font-size: clamp(28px, 3.2vw, 42px);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 1.08;
    color: var(--color-text);
  }

  .subhero__desc {
    font-size: var(--fs-body);
    color: var(--color-text-muted);
    max-width: 480px;
    line-height: 1.55;
  }

  .subhero__stack {
    display: grid;
    grid-template-rows: repeat(3, 1fr);
    gap: 16px;
    min-height: 640px;
  }

  .subhero__photo {
    position: relative;
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow:
      0 18px 40px rgba(0, 0, 0, 0.55),
      0 6px 14px rgba(0, 0, 0, 0.35),
      0 1px 2px rgba(0, 0, 0, 0.4),
      inset 0 0 0 1px rgba(255, 255, 255, 0.35);
    min-height: 170px;
    isolation: isolate;
  }

  .subhero__photo::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    box-shadow: inset 0 0 24px rgba(0, 0, 0, 0.12);
    border-radius: inherit;
    z-index: 1;
  }

  .subhero__photo-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    background-color: #1a1a20;
    filter: brightness(0.98) saturate(1.05);
    transition: transform 0.6s var(--ease-out);
  }

  .subhero__photo:hover .subhero__photo-bg {
    transform: scale(1.04);
  }

  @media (max-width: 1440px) {
    .subhero__grid {
      gap: 20px;
    }
    .subhero__feature {
      min-height: 560px;
    }
    .subhero__feature-content {
      padding: 32px;
      gap: 14px;
    }
    .subhero__stack {
      min-height: 560px;
      gap: 14px;
    }
  }

  @media (max-width: 1024px) {
    .subhero__grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .subhero__feature {
      min-height: 560px;
    }
    .subhero__stack {
      grid-template-rows: none;
      grid-template-columns: repeat(3, 1fr);
      min-height: 0;
      gap: 20px;
    }
    .subhero__photo {
      min-height: 220px;
    }
  }

  @media (max-width: 768px) {
    .subhero__grid {
      gap: 32px;
    }
    .subhero__feature {
      min-height: 440px;
    }
    .subhero__feature-content {
      padding: 24px;
      gap: 12px;
    }
    .subhero__years-num {
      font-size: 40px;
    }
    .subhero__title {
      font-size: 22px;
      line-height: 1.15;
    }
    .subhero__desc {
      font-size: 15px;
      line-height: 1.5;
    }
    .subhero__stack {
      grid-template-columns: 1fr;
      grid-template-rows: repeat(3, auto);
      gap: 24px;
    }
    .subhero__photo {
      min-height: 0;
      aspect-ratio: 16 / 8;
    }
  }

  @media (max-width: 480px) {
    .subhero__feature {
      min-height: 380px;
    }
    .subhero__feature-content {
      padding: 20px;
    }
    .subhero__years-num {
      font-size: 36px;
    }
    .subhero__title {
      font-size: 20px;
    }
    .subhero__desc {
      font-size: 14px;
    }
    .subhero__photo {
      aspect-ratio: 16 / 9;
    }
  }
</style>
