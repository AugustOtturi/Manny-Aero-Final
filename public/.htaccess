# =========================================================
# Manny Aero — .htaccess (Apache + LiteSpeed en Hostinger)
# Compresión + Cache headers + MIME types + SPA fallback
# =========================================================

# ---------------------------------------------------------
# 1) Forzar MIME types correctos
# ---------------------------------------------------------
<IfModule mod_mime.c>
  AddType application/javascript            .js .mjs
  AddType text/css                          .css
  AddType image/svg+xml                     .svg
  AddType image/webp                        .webp
  AddType image/avif                        .avif
  AddType video/mp4                         .mp4
  AddType video/webm                        .webm
  AddType font/woff2                        .woff2
  AddType font/woff                         .woff
  AddType application/json                  .json .geojson
  AddType application/manifest+json         .webmanifest
</IfModule>

# ---------------------------------------------------------
# 2) Compresión (Brotli si está disponible, Gzip como fallback)
# ---------------------------------------------------------
<IfModule mod_brotli.c>
  AddOutputFilterByType BROTLI_COMPRESS text/html text/plain text/css text/xml text/javascript
  AddOutputFilterByType BROTLI_COMPRESS application/javascript application/json application/xml
  AddOutputFilterByType BROTLI_COMPRESS application/rss+xml application/atom+xml
  AddOutputFilterByType BROTLI_COMPRESS image/svg+xml application/manifest+json
  AddOutputFilterByType BROTLI_COMPRESS font/ttf font/otf
</IfModule>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css text/xml text/javascript
  AddOutputFilterByType DEFLATE application/javascript application/json application/xml
  AddOutputFilterByType DEFLATE application/rss+xml application/atom+xml
  AddOutputFilterByType DEFLATE image/svg+xml application/manifest+json
  AddOutputFilterByType DEFLATE font/ttf font/otf
  # No comprimir archivos ya comprimidos
  SetEnvIfNoCase Request_URI \
    \.(?:gif|jpe?g|png|webp|avif|mp4|webm|woff2?|zip|gz|br)$ no-gzip dont-vary
</IfModule>

# LiteSpeed también habilita Brotli vía este flag
<IfModule LiteSpeed>
  SetEnv enable-brotli 1
</IfModule>

# ---------------------------------------------------------
# 3) Cache-Control headers por tipo de recurso
# ---------------------------------------------------------
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresDefault                              "access plus 1 month"

  # HTML: siempre revalidar (el contenido cambia con cada deploy)
  ExpiresByType text/html                     "access plus 0 seconds"

  # Assets con hash en el nombre (Astro _astro/*): cache agresivo 1 año
  # (manejado con Header más abajo por path)

  # CSS y JS sin hash: 1 semana
  ExpiresByType text/css                      "access plus 1 week"
  ExpiresByType application/javascript        "access plus 1 week"

  # Imágenes: 6 meses
  ExpiresByType image/jpeg                    "access plus 6 months"
  ExpiresByType image/png                     "access plus 6 months"
  ExpiresByType image/webp                    "access plus 6 months"
  ExpiresByType image/avif                    "access plus 6 months"
  ExpiresByType image/svg+xml                 "access plus 6 months"
  ExpiresByType image/x-icon                  "access plus 1 year"

  # Fuentes: 1 año (casi nunca cambian)
  ExpiresByType font/woff2                    "access plus 1 year"
  ExpiresByType font/woff                     "access plus 1 year"
  ExpiresByType font/ttf                      "access plus 1 year"

  # Video: 1 mes
  ExpiresByType video/mp4                     "access plus 1 month"
  ExpiresByType video/webm                    "access plus 1 month"

  # JSON / GeoJSON: 1 semana
  ExpiresByType application/json              "access plus 1 week"

  # Manifest y robots: 1 día
  ExpiresByType application/manifest+json     "access plus 1 day"
  ExpiresByType text/plain                    "access plus 1 day"
</IfModule>

# ---------------------------------------------------------
# 4) Cache-Control headers modernos (Cache-Control + immutable)
# ---------------------------------------------------------
<IfModule mod_headers.c>
  # Assets con hash de Astro (_astro/*): 1 año + immutable
  <FilesMatch "\.(js|mjs|css|woff2?|ttf|eot)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  <FilesMatch "\.(jpg|jpeg|png|webp|avif|gif|svg|ico)$">
    Header set Cache-Control "public, max-age=15552000"
  </FilesMatch>

  <FilesMatch "\.(mp4|webm|ogg|mp3|wav|flac|aac)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>

  # HTML: no-cache para asegurar que siempre se lea el último
  <FilesMatch "\.(html|htm)$">
    Header set Cache-Control "public, max-age=0, must-revalidate"
  </FilesMatch>

  # JSON/GeoJSON: cache medio
  <FilesMatch "\.(json|geojson)$">
    Header set Cache-Control "public, max-age=604800"
  </FilesMatch>

  # Remover ETags (Last-Modified + Cache-Control es suficiente)
  Header unset ETag
  FileETag None

  # Headers de seguridad básicos
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Permissions-Policy "geolocation=(), microphone=(), camera=()"

  # CORS para fuentes (por si se sirven desde un subdominio)
  <FilesMatch "\.(woff2?|ttf|eot|otf)$">
    Header set Access-Control-Allow-Origin "*"
  </FilesMatch>
</IfModule>

# ---------------------------------------------------------
# 5) Forzar HTTPS (Hostinger normalmente ya lo hace vía panel)
# ---------------------------------------------------------
<IfModule mod_rewrite.c>
  RewriteEngine On

  # HTTPS redirect (Hostinger normalmente ya fuerza HTTPS en el panel)
  RewriteCond %{HTTPS} off
  RewriteCond %{HTTP:X-Forwarded-Proto} !https
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>

# ---------------------------------------------------------
# 6) Desactivar el listado de directorios
# ---------------------------------------------------------
Options -Indexes

# ---------------------------------------------------------
# 7) Proteger archivos sensibles
# ---------------------------------------------------------
<FilesMatch "(^\.|package\.json|package-lock\.json|astro\.config|tsconfig|\.env)">
  Require all denied
</FilesMatch>
