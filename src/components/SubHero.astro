---
import GlassButton from "./ui/GlassButton.astro";
---

<section class="subhero section" id="about" aria-labelledby="subhero-title">
  <div class="container">
    <div class="subhero__grid">
      <article class="subhero__feature reveal">
        <div class="subhero__feature-img" aria-hidden="true"></div>
        <div class="subhero__feature-overlay" aria-hidden="true"></div>
        <div class="subhero__feature-content">
          <p class="subhero__years">
            <span class="subhero__years-num">25+</span>
          </p>
          <h2 id="subhero-title" class="subhero__title">
            Years of experience,<br />
            precision and trust
          </h2>
          <p class="subhero__desc">
            FBO coordination, permits, catering, and ground handling — executed
            with precision, 24/7.
          </p>
          <GlassButton href="#about" variant="outline">Meet Our Founder</GlassButton>
        </div>
      </article>

      <div class="subhero__stack">
        <div class="subhero__photo reveal" aria-label="Manny agents on tarmac">
          <div class="subhero__photo-bg subhero__photo-bg--1"></div>
        </div>
        <div class="subhero__photo reveal" aria-label="Technician working on landing gear">
          <div class="subhero__photo-bg subhero__photo-bg--2"></div>
        </div>
        <div class="subhero__photo reveal" aria-label="Operations dispatcher with headset">
          <div class="subhero__photo-bg subhero__photo-bg--3"></div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .subhero__grid {
    display: grid;
    grid-template-columns: minmax(0, 1.5fr) minmax(0, 1fr);
    gap: 24px;
    align-items: stretch;
  }

  .subhero__feature {
    position: relative;
    border-radius: var(--radius-lg);
    overflow: hidden;
    min-height: 640px;
    box-shadow:
      0 18px 40px rgba(0, 0, 0, 0.55),
      0 6px 14px rgba(0, 0, 0, 0.35),
      0 1px 2px rgba(0, 0, 0, 0.4),
      inset 0 0 0 1px rgba(255, 255, 255, 0.35);
    isolation: isolate;
  }

  .subhero__feature-img {
    position: absolute;
    inset: 0;
    background-color: #1a1a20;
    background-image:
      linear-gradient(135deg, rgba(42, 42, 48, 0.35) 0%, rgba(15, 15, 21, 0.55) 100%),
      url("https://images.unsplash.com/photo-1569629743817-70d8db6c323b?w=1600&q=80&auto=format&fit=crop");
    background-size: cover;
    background-position: center;
    filter: brightness(0.98) saturate(1.05);
    z-index: -2;
  }

  .subhero__feature-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(168, 164, 164, 0.05) 0%,
      rgba(109, 102, 102, 0.35) 50%,
      rgba(97, 92, 92, 0.85) 100%
    );
    box-shadow: inset 0 0 24px rgba(0, 0, 0, 0.12);
    z-index: -1;
  }

  .subhero__feature-content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 44px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 18px;
  }

  .subhero__years-num {
    font-size: clamp(48px, 6vw, 76px);
    font-weight: 900;
    color: var(--color-accent);
    letter-spacing: -0.03em;
    line-height: 1;
  }

  .subhero__title {
    font-size: clamp(28px, 3.2vw, 42px);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 1.08;
    color: var(--color-text);
  }

  .subhero__desc {
    font-size: var(--fs-body);
    color: var(--color-text-muted);
    max-width: 480px;
    line-height: 1.55;
  }

  .subhero__stack {
    display: grid;
    grid-template-rows: repeat(3, 1fr);
    gap: 16px;
    min-height: 640px;
  }

  .subhero__photo {
    position: relative;
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow:
      0 18px 40px rgba(0, 0, 0, 0.55),
      0 6px 14px rgba(0, 0, 0, 0.35),
      0 1px 2px rgba(0, 0, 0, 0.4),
      inset 0 0 0 1px rgba(255, 255, 255, 0.35);
    min-height: 170px;
    isolation: isolate;
  }

  .subhero__photo::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    box-shadow: inset 0 0 24px rgba(0, 0, 0, 0.12);
    border-radius: inherit;
    z-index: 1;
  }

  .subhero__photo-bg {
    position: absolute;
    inset: 0;
    background-color: #1a1a20;
    background-size: cover;
    background-position: center;
    filter: brightness(0.98) saturate(1.05);
    transition: transform 0.6s var(--ease-out);
  }

  .subhero__photo:hover .subhero__photo-bg {
    transform: scale(1.04);
  }

  .subhero__photo-bg--1 {
    background-image:
      linear-gradient(120deg, rgba(58, 58, 66, 0.25) 0%, rgba(30, 30, 38, 0.4) 100%),
      url("https://images.unsplash.com/photo-1436491865332-7a61a109cc05?w=1000&q=80&auto=format&fit=crop");
  }

  .subhero__photo-bg--2 {
    background-image:
      linear-gradient(120deg, rgba(46, 46, 54, 0.25) 0%, rgba(24, 24, 30, 0.4) 100%),
      url("https://images.unsplash.com/photo-1540962351504-03099e0a754b?w=1000&q=80&auto=format&fit=crop");
  }

  .subhero__photo-bg--3 {
    background-image:
      linear-gradient(120deg, rgba(50, 50, 56, 0.25) 0%, rgba(20, 20, 26, 0.4) 100%),
      url("https://images.unsplash.com/photo-1583416750470-965b2707b355?w=1000&q=80&auto=format&fit=crop");
  }

  @media (max-width: 1024px) {
    .subhero__grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .subhero__feature {
      min-height: 560px;
    }
    .subhero__stack {
      grid-template-rows: none;
      grid-template-columns: repeat(3, 1fr);
      min-height: 0;
      gap: 20px;
    }
    .subhero__photo {
      min-height: 220px;
    }
  }

  @media (max-width: 768px) {
    .subhero__grid {
      gap: 32px;
    }
    .subhero__feature {
      min-height: 440px;
    }
    .subhero__feature-content {
      padding: 24px;
      gap: 14px;
    }
    .subhero__stack {
      grid-template-columns: 1fr;
      grid-template-rows: repeat(3, auto);
      gap: 24px;
    }
    .subhero__photo {
      min-height: 0;
      aspect-ratio: 16 / 8;
    }
  }

  @media (max-width: 480px) {
    .subhero__feature {
      min-height: 380px;
    }
    .subhero__feature-content {
      padding: 20px;
    }
    .subhero__photo {
      aspect-ratio: 16 / 9;
    }
  }
</style>
