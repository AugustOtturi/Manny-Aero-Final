---
import { SERVICES } from "../data/services";
import GlassPill from "./ui/GlassPill.astro";
---

<section class="services section" id="services" aria-labelledby="services-title">
  <div class="container">
    <h2 id="services-title" class="services__title reveal">
      Manny is ready to cover your needs in every flight, offering end-to-end support designed to
      <span class="accent">make your journey smooth, efficient, and stress-free</span> from start to finish.
    </h2>

    <div class="services__grid">
      {
        SERVICES.map((s, i) => (
          <a href={s.href} class={`card card--${s.tone} reveal`} style={`--delay:${i * 80}ms`}>
            <div class="card__img" aria-hidden="true"></div>
            <div class="card__overlay" aria-hidden="true"></div>

            <div class="card__top">
              <GlassPill>Explore More</GlassPill>
            </div>

            <div class="card__bottom">
              <h3 class="card__title">{s.title}</h3>
              <span class="card__arrow" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
                  <path
                    d="M3 9H15M15 9L10 4M15 9L10 14"
                    stroke="currentColor"
                    stroke-width="1.6"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
              </span>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>

<style>
  .services__title {
    font-size: clamp(24px, 2.8vw, 40px);
    font-weight: 800;
    line-height: 1.2;
    letter-spacing: -0.01em;
    text-transform: uppercase;
    text-align: center;
    max-width: 980px;
    margin: 0 auto 60px;
    color: var(--color-text);
    transition-delay: 0.05s;
  }

  .services__title .accent {
    color: var(--color-accent);
  }

  .services__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 18px;
  }

  .card {
    position: relative;
    aspect-ratio: 9 / 20;
    border-radius: var(--radius-lg);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 18px;
    box-shadow: var(--shadow-card);
    transition: transform 0.5s var(--ease-out), box-shadow 0.5s var(--ease-out);
    isolation: isolate;
    transition-delay: var(--delay, 0ms);
  }

  .card:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow-card-lg);
  }

  .card__img {
    position: absolute;
    inset: 0;
    z-index: -2;
    filter: var(--filter-photo);
    transition: transform 0.8s var(--ease-out);
  }

  .card:hover .card__img {
    transform: scale(1.06);
  }

  .card__overlay {
    position: absolute;
    inset: 0;
    z-index: -1;
    background: linear-gradient(
      180deg,
      rgba(0, 0, 0, 0.2) 0%,
      rgba(0, 0, 0, 0.1) 40%,
      rgba(0, 0, 0, 0.9) 100%
    );
  }

  .card--a .card__img {
    background:
      radial-gradient(circle at 40% 30%, rgba(255, 255, 255, 0.1), transparent 55%),
      linear-gradient(180deg, #32322e 0%, #1a1a16 100%);
    filter: var(--filter-photo-bw);
  }

  .card--b .card__img {
    background:
      radial-gradient(circle at 50% 50%, rgba(255, 255, 255, 0.12), transparent 60%),
      linear-gradient(180deg, #2e2e34 0%, #17171c 100%);
    filter: var(--filter-photo-bw);
  }

  .card--c .card__img {
    background:
      radial-gradient(circle at 50% 50%, rgba(255, 180, 90, 0.15), transparent 55%),
      linear-gradient(180deg, #3b2a1a 0%, #1d140a 100%);
  }

  .card--d .card__img {
    background:
      radial-gradient(circle at 50% 30%, rgba(255, 255, 255, 0.1), transparent 55%),
      linear-gradient(180deg, #2a2c30 0%, #14161a 100%);
    filter: var(--filter-photo-bw);
  }

  .card__top {
    display: flex;
  }

  .card__bottom {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 12px;
  }

  .card__title {
    font-size: clamp(15px, 1.2vw, 18px);
    font-weight: 700;
    line-height: 1.25;
    color: var(--color-text);
    max-width: 180px;
  }

  .card__arrow {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.2);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text);
    flex-shrink: 0;
    transition: background-color 0.3s var(--ease-out), color 0.3s var(--ease-out);
  }

  .card:hover .card__arrow {
    background: var(--color-accent);
    color: #0a0a0a;
    border-color: var(--color-accent);
  }

  @media (max-width: 1024px) {
    .services__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 14px;
    }
    /* Shorter cards in 2-col tablet view */
    .card {
      aspect-ratio: 3 / 4;
    }
    .card__title {
      font-size: 15px;
    }
  }

  @media (max-width: 640px) {
    .services__grid {
      grid-template-columns: 1fr 1fr;
      gap: 10px;
    }
    .card {
      aspect-ratio: 2 / 3;
    }
    .services__title {
      font-size: clamp(18px, 5vw, 26px);
      margin-bottom: 32px;
    }
  }

  @media (max-width: 420px) {
    .services__grid {
      grid-template-columns: 1fr;
    }
    .card {
      aspect-ratio: 16 / 10;
    }
  }
</style>
