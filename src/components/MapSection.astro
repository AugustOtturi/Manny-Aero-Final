---
import { PINS, LEGEND, STATS } from "../data/airports";
---

<section class="map-section section" id="map" aria-labelledby="map-title">
  <div class="container">
    <h2 id="map-title" class="map__title reveal">
      Aircraft handling covering all airports throughout Mexico — Manny's
      services cover all of Mexico with 7 offices strategically positioned at
      <span class="accent">the most important locations.</span>
    </h2>

    <div class="map__wrap reveal">
      <div class="map__canvas" role="img" aria-label="Map of Mexico showing Manny Aero agent locations">
        <div class="map__placeholder">
          <svg
            class="map__placeholder-icon"
            width="48"
            height="48"
            viewBox="0 0 24 24"
            fill="none"
            aria-hidden="true"
          >
            <path
              d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5a2.5 2.5 0 1 1 0-5 2.5 2.5 0 0 1 0 5z"
              fill="currentColor"
              opacity="0.4"
            />
          </svg>
          <p class="map__placeholder-text">Mexico map — asset pendiente</p>
        </div>

        {
          PINS.map((p) => (
            <span
              class={`pin pin--${p.color}`}
              style={`--x:${p.xPct}%; --y:${p.yPct}%;`}
              title={p.label}
              aria-label={p.label}
            >
              <svg viewBox="0 0 32 42" aria-hidden="true">
                <path
                  d="M16 0C7.2 0 0 7.2 0 16c0 11 16 26 16 26s16-15 16-26c0-8.8-7.2-16-16-16z"
                  fill="currentColor"
                />
                <circle cx="16" cy="16" r="6" fill="rgba(0,0,0,0.35)" />
              </svg>
            </span>
          ))
        }
      </div>
    </div>

    <ul class="map__legend reveal" aria-label="Map legend">
      {
        LEGEND.map((l) => (
          <li class="map__legend-item">
            <span class={`dot dot--${l.color}`} aria-hidden="true" />
            <span>{l.label}</span>
          </li>
        ))
      }
    </ul>

    <div class="map__stats reveal">
      {
        STATS.map((s) => (
          <div class="stat">
            <span class="stat__value">{s.value}</span>
            <p class="stat__label">{s.label}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .map__title {
    font-size: clamp(26px, 3vw, 44px);
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: -0.01em;
    text-transform: uppercase;
    max-width: 1040px;
    color: var(--color-text);
    margin-bottom: 56px;
  }

  .map__wrap {
    max-width: 880px;
    margin: 0 auto;
  }

  .map__canvas {
    position: relative;
    width: 100%;
    aspect-ratio: 4 / 3;
    border-radius: var(--radius-lg);
  }

  .map__placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 12px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px dashed var(--color-border);
    border-radius: var(--radius-lg);
    color: var(--color-text-dim);
  }

  .map__placeholder-text {
    font-size: var(--fs-label);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .pin {
    position: absolute;
    left: var(--x);
    top: var(--y);
    transform: translate(-50%, -100%);
    width: 28px;
    height: 36px;
    filter: drop-shadow(0 4px 10px rgba(0, 0, 0, 0.4));
    transition: transform 0.25s var(--ease-out);
    cursor: pointer;
  }

  .pin:hover {
    transform: translate(-50%, -100%) scale(1.15);
    z-index: 3;
  }

  .pin svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .pin--gold {
    color: var(--pin-gold);
  }
  .pin--red {
    color: var(--pin-red);
  }
  .pin--blue {
    color: var(--pin-blue);
  }
  .pin--orange {
    color: var(--pin-orange);
  }

  .map__legend {
    list-style: none;
    padding: 0;
    margin: 44px 0 0;
    display: flex;
    gap: clamp(32px, 6vw, 96px);
    justify-content: center;
    flex-wrap: wrap;
  }

  .map__legend-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    font-size: var(--fs-micro);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    font-weight: 600;
  }

  .dot {
    width: 14px;
    height: 14px;
    border-radius: 50%;
  }

  .dot--gold {
    background: var(--pin-gold);
  }
  .dot--red {
    background: var(--pin-red);
  }
  .dot--blue {
    background: var(--pin-blue);
  }
  .dot--orange {
    background: var(--pin-orange);
  }

  .map__stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-top: 72px;
    border-top: 1px solid var(--color-border);
    padding-top: 56px;
  }

  .stat {
    text-align: center;
    padding: 0 16px;
  }

  .stat + .stat {
    border-left: 1px solid var(--color-border);
  }

  .stat__value {
    display: block;
    font-size: clamp(40px, 6vw, 72px);
    font-weight: 900;
    color: var(--color-accent);
    line-height: 1;
    letter-spacing: -0.03em;
    margin-bottom: 14px;
  }

  .stat__label {
    font-size: var(--fs-micro);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    line-height: 1.4;
    max-width: 220px;
    margin: 0 auto;
  }

  @media (max-width: 1024px) {
    .map__title {
      font-size: clamp(22px, 3.5vw, 36px);
      margin-bottom: 36px;
    }
  }

  @media (max-width: 768px) {
    .map__wrap {
      max-width: 100%;
    }
    .map__canvas {
      aspect-ratio: 4 / 3;
    }
    .map__stats {
      grid-template-columns: 1fr;
      gap: 0;
      margin-top: 48px;
      padding-top: 40px;
    }
    .stat + .stat {
      border-left: none;
      border-top: 1px solid var(--color-border);
      padding-top: 32px;
      margin-top: 32px;
    }
    .map__legend {
      gap: 20px;
      flex-wrap: wrap;
      justify-content: center;
    }
    .stat__value {
      font-size: clamp(36px, 10vw, 56px);
    }
  }

  @media (max-width: 480px) {
    .map__legend {
      gap: 16px;
    }
    .map__legend-item {
      font-size: 10px;
    }
  }
</style>
